<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true"
    tools:context=".views.HomeFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- SECCIÓN 1: HERO (Bienvenida) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="32dp"
                android:gravity="center">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/heroSliptTitle"
                    android:textAlignment="center"
                    android:textColor="@color/primaryColor"
                    android:textSize="@dimen/text_hero"
                    android:textStyle="bold"
                    android:lineSpacingExtra="4dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/heroSplitDesc"
                    android:textAlignment="center"
                    android:textColor="@color/secondaryColor"
                    android:textSize="@dimen/text_body"
                    android:alpha="0.8"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_hero_start"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/heroSplitBtn"
                    android:paddingHorizontal="40dp"
                    android:paddingVertical="12dp"
                    app:cornerRadius="30dp"
                    android:backgroundTint="@color/primaryColor"
                    android:textSize="@dimen/text_body"
                    android:textAllCaps="false"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- SECCIÓN 2: BENEFICIOS -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="@string/featureHeroTitle"
            android:textSize="@dimen/text_title"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/featureHeroDesc"
            android:textSize="@dimen/text_subtitle"
            android:textColor="@color/secondaryColor"
            android:alpha="0.7"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="20dp">

            <!-- Item 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/featuresHeroItemTitle1"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold"
                    android:textColor="@color/primaryColor"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/featuresHeroItemDesc1"
                    android:textSize="14sp"
                    android:textColor="@color/secondaryColor"
                    android:alpha="0.8"/>
            </LinearLayout>

            <!-- Item 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/featuresHeroItemTitle2"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold"
                    android:textColor="@color/primaryColor"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/featuresHeroItemDesc2"
                    android:textSize="14sp"
                    android:textColor="@color/secondaryColor"
                    android:alpha="0.8"/>
            </LinearLayout>

            <!-- Item 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/featuresHeroItemTitle3"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold"
                    android:textColor="@color/primaryColor"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/featuresHeroItemDesc3"
                    android:textSize="14sp"
                    android:textColor="@color/secondaryColor"
                    android:alpha="0.8"/>
            </LinearLayout>

            <!-- Item 4 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/featuresHeroItemTitle4"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold"
                    android:textColor="@color/primaryColor"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/featuresHeroItemDesc4"
                    android:textSize="14sp"
                    android:textColor="@color/secondaryColor"
                    android:alpha="0.8"/>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_features_more"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/featuresHeroBtn"
                app:strokeColor="@color/primaryColor"
                android:textColor="@color/primaryColor"
                app:cornerRadius="12dp"
                android:textAllCaps="false"/>
        </LinearLayout>

        <!-- Divisor sutil -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="40dp"
            android:background="#EEEEEE"/>

        <!-- SECCIÓN 3: SERVICIOS -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/featureTitle"
            android:textSize="@dimen/text_title"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/featureDesciption"
            android:textSize="@dimen/text_subtitle"
            android:textColor="@color/secondaryColor"
            android:alpha="0.7"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="40dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/featureListItemH1"
                android:textSize="@dimen/text_body"
                android:textStyle="bold"
                android:textColor="@color/primaryColor"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/featureListItemD1"
                android:textSize="14sp"
                android:textColor="@color/secondaryColor"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/featureListItemH2"
                android:textSize="@dimen/text_body"
                android:textStyle="bold"
                android:textColor="@color/primaryColor"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/featureListItemD2"
                android:textSize="14sp"
                android:textColor="@color/secondaryColor"/>
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
