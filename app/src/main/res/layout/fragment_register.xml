<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundSecondary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Misma cabecera que Home / detalle huerta -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/primaryColor"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="32dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/auth_register_welcome"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:alpha="0.85" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/app_name"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/auth_register_subtitle"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:alpha="0.85"
                android:lineSpacingExtra="2dp" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="28dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/backgroundPrimary">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/tvRegister"
                    android:textColor="@color/textSecondary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="14dp"
                    android:text="@string/auth_card_hint_register"
                    android:textColor="@color/secondaryColor"
                    android:textSize="12sp"
                    android:alpha="0.75" />

                <!-- Nombres -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/etNombres"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/textSecondary" />
                <EditText
                    android:id="@+id/etNombres"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/input_background"
                    android:hint="@string/etNombres"
                    android:autofillHints="name"
                    android:inputType="textPersonName|textCapWords"
                    android:paddingHorizontal="14dp"
                    android:textSize="15sp"
                    tools:ignore="Autofill" />

                <!-- Apellidos -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/etApellidos"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/textSecondary" />
                <EditText
                    android:id="@+id/etApellidos"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/input_background"
                    android:hint="@string/etApellidos"
                    android:autofillHints="familyName"
                    android:inputType="textPersonName|textCapWords"
                    android:paddingHorizontal="14dp"
                    android:textSize="15sp"
                    tools:ignore="Autofill" />

                <!-- Correo -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/etRegisterCorreo"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/textSecondary" />
                <EditText
                    android:id="@+id/etRegisterCorreo"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/input_background"
                    android:hint="@string/etRegisterCorreo"
                    android:autofillHints="emailAddress"
                    android:inputType="textEmailAddress"
                    android:paddingHorizontal="14dp"
                    android:textSize="15sp"
                    tools:ignore="Autofill" />

                <!-- Contraseña -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/etRegisterContraseña"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/textSecondary" />
                <EditText
                    android:id="@+id/etRegisterContrasena"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/input_background"
                    android:hint="@string/etRegisterContraseña"
                    android:autofillHints="password"
                    android:inputType="textPassword"
                    android:paddingHorizontal="14dp"
                    android:textSize="15sp"
                    tools:ignore="Autofill" />

                <!-- Confirmar -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/etRegisterContraseña2"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/textSecondary" />
                <EditText
                    android:id="@+id/etRegisterContrasena2"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/input_background"
                    android:hint="@string/etRegisterContraseña2"
                    android:autofillHints="password"
                    android:inputType="textPassword"
                    android:paddingHorizontal="14dp"
                    android:textSize="15sp"
                    tools:ignore="Autofill" />

                <CheckBox
                    android:id="@+id/cbTerminos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/cbTerminos"
                    android:textColor="@color/secondaryColor"
                    android:buttonTint="@color/primaryColor" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRegistrar"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:text="@string/btnRegister"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    app:cornerRadius="12dp"
                    app:backgroundTint="@color/primaryColor" />

                <TextView
                    android:id="@+id/tvIniciaSesion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center"
                    android:text="@string/register_login_footer"
                    android:textSize="14sp"
                    android:textColor="@color/secondaryColor" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
