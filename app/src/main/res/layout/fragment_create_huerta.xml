<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundSecondary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Título -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/crear_huerta"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/textSecondary"
            android:layout_marginBottom="8dp" />

        <View
            android:layout_width="48dp"
            android:layout_height="4dp"
            android:background="@color/primaryColor"
            android:layout_marginBottom="32dp" />

        <!-- Card del formulario -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/backgroundPrimary"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Nombre de la huerta -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nombre_huerta"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/textSecondary"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/etNombreHuerta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Ej: Huerta El Rosal"
                    android:inputType="textCapSentences"
                    android:maxLines="1"
                    android:padding="12dp"
                    android:background="@drawable/input_background"
                    android:layout_marginBottom="20dp" />

                <!-- Dirección -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/direccion_huerta"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/textSecondary"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/etDireccionHuerta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Ej: Calle 10 #45-20, Bogotá"
                    android:inputType="textPostalAddress"
                    android:maxLines="1"
                    android:padding="12dp"
                    android:background="@drawable/input_background"
                    android:layout_marginBottom="20dp" />

                <!-- Descripción -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/descripcion_huerta"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/textSecondary"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/etDescripcionHuerta"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:hint="Describe tu huerta..."
                    android:inputType="textMultiLine|textCapSentences"
                    android:gravity="top|start"
                    android:padding="12dp"
                    android:background="@drawable/input_background" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Indicador de carga -->
        <ProgressBar
            android:id="@+id/progressBarHuerta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            android:indeterminateTint="@color/primaryColor" />

        <!-- Botones -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btnCancelarHuerta"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="@string/btn_cancelar"
                android:textColor="@color/primaryColor"
                android:backgroundTint="@color/backgroundPrimary"
                android:strokeColor="@color/primaryColor"
                android:layout_marginEnd="8dp"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <Button
                android:id="@+id/btnGuardarHuerta"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="@string/btn_guardar"
                android:textColor="@color/white"
                android:backgroundTint="@color/primaryColor"
                android:layout_marginStart="8dp"
                style="@style/Widget.Material3.Button" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
